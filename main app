@app.post("/api/register")
async def register(request: Request):
    data = await request.json()
    conn = get_db()
    try:
        hashed = get_password_hash(data['password'])
        conn.execute("INSERT INTO businesses (name, email, password, phone_number) VALUES (?, ?, ?, ?)",
                     (data['name'], data['email'], hashed, data['phone_number']))
        conn.commit()
        cursor = conn.execute("SELECT id FROM businesses WHERE email = ?", (data['email'],))
        business = cursor.fetchone()
        token = jwt.encode({"sub": business['id']}, SECRET_KEY)
        return {"token": token}
    except Exception as e:
        raise HTTPException(400, str(e))
    finally:
        conn.close()

@app.get("/api/calls")
async def get_calls(request: Request):
    auth = request.headers.get('Authorization')
    if not auth:
        raise HTTPException(401)
    token = auth.replace('Bearer ', '')
    try:
        payload = jwt.decode(token, SECRET_KEY)
        business_id = payload.get('sub')
    except:
        raise HTTPException(401)
    conn = get_db()
    calls = conn.execute("SELECT * FROM call_logs WHERE business_id = ? ORDER BY timestamp DESC", (business_id,)).fetchall()
    conn.close()
    return [dict(call) for call in calls]

@app.post("/api/forwarding")
async def update_forwarding(request: Request):
    auth = request.headers.get('Authorization')
    if not auth:
        raise HTTPException(401)
    token = auth.replace('Bearer ', '')
    data = await request.json()
    try:
        payload = jwt.decode(token, SECRET_KEY)
        business_id = payload.get('sub')
    except:
        raise HTTPException(401)
    conn = get_db()
    conn.execute("UPDATE businesses SET forwarding_number = ? WHERE id = ?", (data['forwarding_number'], business_id))
    conn.commit()
    conn.close()
    return {"status": "updated"}

@app.post("/twilio/incoming")
async def twilio_incoming(request: Request):
    form = await request.form()
    caller_id = form.get('Caller')
    call_sid = form.get('CallSid')
    
    conn = get_db()
    business = conn.execute("SELECT * FROM businesses WHERE phone_number = ?", (caller_id,)).fetchone()
    
    resp = VoiceResponse()
    if not business:
        resp.say("Service not active. Goodbye.")
        conn.close()
        return Response(content=str(resp), media_type="application/xml")
    
    conn.execute("INSERT INTO call_logs (business_id, caller_number, call_sid) VALUES (?, ?, ?)",
                 (business['id'], form.get('From'), call_sid))
    conn.commit()
    conn.close()
    
    gather = Gather(num_digits=1, action=f"/twilio/menu/{call_sid}", method="POST")
    gather.say(f"Thank you for calling. Press 1 for appointment, 2 to speak to someone, 3 for message.")
    resp.append(gather)
    
    return Response(content=str(resp), media_type="application/xml")

@app.post("/twilio/menu/{call_sid}")
async def twilio_menu(call_sid: str, request: Request):
    form = await request.form()
    digits = form.get('Digits')
    
    conn = get_db()
    business = conn.execute("""
        SELECT b.* FROM businesses b 
        JOIN call_logs c ON b.id = c.business_id 
        WHERE c.call_sid = ?
    """, (call_sid,)).fetchone()
    
    resp = VoiceResponse()
    
    if digits == "2" and business and business['forwarding_number']:
        resp.say("Connecting you now.")
        resp.dial(business['forwarding_number'])
    elif digits in ["1", "3"]:
        action = "appointment" if digits == "1" else "message"
        resp.say(f"Please record your {action} after the beep.")
        resp.record(max_length=60, action=f"/twilio/save/{call_sid}/{action}", method="POST")
    else:
        resp.say("Goodbye.")
    
    conn.close()
    return Response(content=str(resp), media_type="application/xml")

@app.post("/twilio/save/{call_sid}/{action}")
async def twilio_save(call_sid: str, action: str, request: Request):
    form = await request.form()
    recording_url = form.get('RecordingUrl')
    
    conn = get_db()
    conn.execute("UPDATE call_logs SET action_taken = ?, recording_url = ? WHERE call_sid = ?",
                 (action, recording_url, call_sid))
    conn.commit()
    conn.close()
    
    resp = VoiceResponse()
    resp.say("Thank you. Goodbye.")
    return Response(content=str(resp), media_type="application/xml")

